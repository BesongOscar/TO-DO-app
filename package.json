    "e2e:profile": "maestro test .maestro/flows/05-profile.yaml",
    "e2e:details": "maestro test .maestro/flows/06-task-details.yaml",
    "e2e:bulk": "maestro test .maestro/flows/07-bulk-actions.yaml",
