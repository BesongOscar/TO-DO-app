{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",

    "paths": {
      "@/components/*": ["./components/*"],
      "@/context/*": ["./src/context/*"],
      "@/firebase/*": ["./src/firebase/*"],
      "@/src/*": ["./src/*"],
      "@/styles/*": ["./styles/*"],
      "assets/*": ["./assets/*"]
    },
    "typeRoots": ["./node_modules/@types", "./types"],
    "esModuleInterop": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "types/**/*.d.ts"
  ]
}
